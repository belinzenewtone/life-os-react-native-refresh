    "e2e:maestro:auth": "maestro test e2e/maestro/auth-onboarding-flow.yaml",
    "e2e:maestro:tabs": "maestro test e2e/maestro/core-tab-navigation-flow.yaml",
    "e2e:maestro:assistant": "maestro test e2e/maestro/assistant-proposal-flow.yaml",
    "e2e:maestro:android-finance": "maestro test e2e/maestro/finance-android-sms-flow.yaml",
    "e2e:maestro:ios-finance": "maestro test e2e/maestro/finance-ios-cloud-flow.yaml"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
