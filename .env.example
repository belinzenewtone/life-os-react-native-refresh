EXPO_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
# Optional alternative for newer Supabase projects that provide publishable keys.
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<publishable-key>
EXPO_PUBLIC_ASSISTANT_PROXY_URL=https://<project>.supabase.co/functions/v1/assistant-proxy
EXPO_PUBLIC_OTA_MANIFEST_URL=https://raw.githubusercontent.com/belinzenewtone/life-os-react-native-refresh/master/ota/manifest.json
EXPO_PUBLIC_BINARY_VERSION_ENDPOINT=https://raw.githubusercontent.com/belinzenewtone/life-os-react-native-refresh/master/ota/binary-version.json
